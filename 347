class Solution {
public:
    vector<int> topKFrequent(vector<int>& nums, int k) {
        int n=nums.size();
        map<int,int>mp;
        for(auto c:nums) mp[c]++;
        vector<vector<int>>b(n+1);
        for(auto &p:mp) b[p.second].push_back(p.first);
        vector<int>res;
        for(int i=n;i>=0 && res.size()<k;i--){
            for(auto x:b[i]){
                res.push_back(x);
                if(res.size()==k) break;
            }
        }
        return res;
    }
};

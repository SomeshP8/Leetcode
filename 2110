class Solution {
public:
    long long getDescentPeriods(vector<int>& prices) {
        int n=prices.size();
        long long l=1,a=1;
        for(int i=1;i<n;i++){
            if(prices[i]==prices[i-1]-1){
             l++;
            }
            else{
                l=1;
            }
            a+=l;
        }
        return a;
    }
};

class Solution {
public:
    int minimumBoxes(vector<int>& apple, vector<int>& capacity) {
        int sum=0;
        int n=apple.size();
        for(int i=0;i<n;i++) sum+=apple[i];
        sort(capacity.rbegin(),capacity.rend());
        int c=0;
        for(int i=0;i<capacity.size();i++){
            sum-=capacity[i];
            c++;
            if(sum<=0) break;
        }
        return c;
    }
};

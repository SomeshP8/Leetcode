class Solution {
public:
    int numDecodings(string s) {
        if(s[0]=='0') return 0;
        int prev=1,curr=1;
        for(int i=1;i<s.size();i++){
        int temp=0;
        if(s[i]!='0'){
            temp+=curr;
        }
        int td=(s[i-1]-'0')*10+(s[i]-'0');
        if(td>=10 && td<=26){
          temp+=prev;
        }
        prev=curr;
        curr=temp;
    }
   return curr;
    }
};
